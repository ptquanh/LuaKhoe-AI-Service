# API Settings
DEBUG=True
PORT=8000
HOST=0.0.0.0

# Active Model Strategy
# Options: cnn_mvp, advanced_hybrid, onnx_runtime
ACTIVE_MODEL_STRATEGY=onnx_runtime
MODEL_WEIGHTS_PATH=models/v1_cnn_mvp.onnx

# Input Specifications
IMAGE_INPUT_SIZE=224

# Inference Settings
CONFIDENCE_THRESHOLD=0.75

# Storage Strategy (local or s3)
STORAGE_TYPE=local
UPLOAD_DIR=data/uploads

# Disease Labels (Comma-separated)
DISEASE_LABELS=Healthy,Bacterial_Leaf_Blight,Brown_Spot,Leaf_Blast,Leaf_Smut

# ---------- RAG Pipeline (NEW) ----------

# PostgreSQL + pgvector connection
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/luakhoe

# Google Gemini API Key (required for RAG pipeline)
GOOGLE_API_KEY=your_gemini_api_key_here

# Gemini Model Configuration
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
GROQ_LLM_MODEL=gemma2-9b-it
GROQ_API_KEY=your_groq_api_key_here

# RAG Retrieval Tuning
RAG_SIMILARITY_THRESHOLD=0.65
RAG_TOP_K=5
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
